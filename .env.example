# Server
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=30d

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/belgrade_calendar

# Telegram
BOT_TOKEN=
BOT_USERNAME=BelgradeCalendarBot
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_IDS=

# URLs — для ngrok-теста Mini App замени на https://xxxx.ngrok-free.app
WEBAPP_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:5173/api
BOT_WEBHOOK_URL=https://belca.jtutor.app/bot/webhook

# App
TZ=Europe/Belgrade

# Bot service (telegram-bot/)
BOT_PORT=3001
BOT_USE_POLLING=true
